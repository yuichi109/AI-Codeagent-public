AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# カンマ区切りで複数指定可（省略時は AZURE_OPENAI_DEPLOYMENT のみ）
AZURE_OPENAI_DEPLOYMENTS=gpt-5-mini,gpt-4.1-mini,gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure AI Foundry インスタンス 1（省略可 — 設定するとプルダウンで切り替え可能）
FOUNDRY_NAME=Azure AI Foundry
FOUNDRY_ENDPOINT=https://your-project.cognitiveservices.azure.com/
FOUNDRY_API_KEY=your_foundry_api_key_here
FOUNDRY_MODEL=gpt-4.1-mini
FOUNDRY_API_VERSION=2024-12-01-preview
# カンマ区切りで複数モデルを指定可（省略時は FOUNDRY_MODEL のみ）
FOUNDRY_MODELS=gpt-5-mini,gpt-4.1-mini

# Azure AI Foundry インスタンス 2（省略可 — N を増やして複数追加できる）
# FOUNDRY_2_NAME=別リージョン
# FOUNDRY_2_ENDPOINT=https://another.cognitiveservices.azure.com/
# FOUNDRY_2_API_KEY=your_api_key_here
# FOUNDRY_2_MODEL=gpt-4.1
# FOUNDRY_2_API_VERSION=2024-12-01-preview
# FOUNDRY_2_MODELS=gpt-4.1,gpt-4.1-mini

# エージェント名（自己紹介時に使う名前。未設定時はモデルが適当に答える）
# AGENT_NAME=SPEC-AI

ALLOWED_WORK_DIR=./workspace
COMMAND_TIMEOUT_SECONDS=30

# プロキシバイパス (社内プロキシ環境の場合に設定)
# ※ プロキシが不要な環境ではこのまま記載していても問題なし
no_proxy=*.azure.com,*.openai.azure.com,gitlab.com,api.duckduckgo.com,html.duckduckgo.com,ja.wikipedia.org,en.wikipedia.org,localhost,127.0.0.1
NO_PROXY=*.azure.com,*.openai.azure.com,gitlab.com,api.duckduckgo.com,html.duckduckgo.com,ja.wikipedia.org,en.wikipedia.org,localhost,127.0.0.1

# SearXNG 検索バックエンド (自前ホスト)
# docker compose -f docker-compose.searxng.yml up -d で起動
SEARXNG_BASE_URL=http://localhost:8888
SEARXNG_ENABLED=false
