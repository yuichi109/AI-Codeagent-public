{
  "servers": [
    {
      "id": "playwright",
      "name": "Playwright MCP",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium",
        "--output-dir",
        "./workspace/playwright-screenshots"
      ],
      "enabled": true
    },
    {
      "id": "obsidian",
      "name": "Obsidian MCP",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "obsidian-mcp",
        "${OBSIDIAN_VAULT_PATH}"
      ],
      "timeout": 120,
      "enabled": true
    }
  ]
}